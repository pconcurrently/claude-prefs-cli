#!/usr/bin/env bash
# claude-prefs - Manage global Claude Code memories, skills, and sync them to projects
# Usage: claude-prefs <command> [args]

set -euo pipefail

REPO_URL="https://github.com/pconcurrently/claude-prefs-cli"

trap 'echo -e "\n\033[0;90mIf this looks like a bug, try: claude-prefs update\033[0m"; echo -e "\033[0;90mOr report it at: ${REPO_URL}/issues\033[0m"' ERR

CLAUDE_DIR="$HOME/.claude"
GLOBAL_DIR="$CLAUDE_DIR/global-memory"
PROJECTS_DIR="$CLAUDE_DIR/projects"
SKILLS_FILE="$CLAUDE_DIR/global-skills.json"

# Resolve defaults directory relative to the script location
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
DEFAULTS_DIR="$SCRIPT_DIR/defaults"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m'
REVERSE='\033[7m'

# Ensure global memory directory exists
mkdir -p "$GLOBAL_DIR"

# Ensure skills file exists
if [[ ! -f "$SKILLS_FILE" ]]; then
  echo '[]' > "$SKILLS_FILE"
fi

# ---------------------------------------------------------------------------
# Interactive multi-select picker
# Uses arrow keys to navigate, space to toggle, enter to confirm, a to toggle all
# Arguments: prompt, then pairs of (label, key) passed as positional args
# Selected keys are written to stdout, one per line
# ---------------------------------------------------------------------------

# Multi-select picker that writes results to a temp file
# Usage: multi_select <result_file> <prompt> [--default-off] <label1> <key1> <label2> <key2> ...
# Selected keys are written to result_file, one per line
multi_select() {
  local result_file="$1"
  local prompt="$2"
  shift 2

  local default_on=1
  if [[ "${1:-}" == "--default-off" ]]; then
    default_on=0
    shift
  fi

  local -a labels=()
  local -a keys=()
  local -a selected=()

  # Parse label|key pairs
  while [[ $# -gt 0 ]]; do
    labels+=("$1")
    keys+=("$2")
    selected+=($default_on)
    shift 2
  done

  local total=${#labels[@]}
  if [[ $total -eq 0 ]]; then
    return
  fi

  local cursor=0

  # Save terminal state and hide cursor
  tput civis 2>/dev/null || true

  draw_menu() {
    # Move to start position and clear
    echo -ne "\033[${total}A" 2>/dev/null || true
    echo -ne "\r"

    for i in $(seq 0 $((total - 1))); do
      local check=" "
      [[ ${selected[$i]} -eq 1 ]] && check="${GREEN}x${NC}"

      local line="  [$check] ${labels[$i]}"
      if [[ $i -eq $cursor ]]; then
        line="  ${REVERSE}[$check] ${labels[$i]}${NC}"
      fi

      echo -e "\033[2K${line}"
    done
  }

  # Print prompt and initial menu
  echo -e "${BOLD}${prompt}${NC}"
  echo -e "${DIM}  [space] toggle  [a] all/none  [enter] confirm${NC}"
  echo ""

  # Print placeholder lines
  for i in $(seq 0 $((total - 1))); do
    echo ""
  done

  draw_menu

  # Read input
  while true; do
    # Read a single keypress
    IFS= read -rsn1 key

    case "$key" in
      # Arrow keys: escape sequence
      $'\x1b')
        read -rsn2 rest
        case "$rest" in
          '[A') # Up
            cursor=$(( (cursor - 1 + total) % total ))
            ;;
          '[B') # Down
            cursor=$(( (cursor + 1) % total ))
            ;;
        esac
        ;;
      ' ') # Space - toggle current
        if [[ ${selected[$cursor]} -eq 1 ]]; then
          selected[$cursor]=0
        else
          selected[$cursor]=1
        fi
        ;;
      'a'|'A') # Toggle all
        local all_on=1
        for i in $(seq 0 $((total - 1))); do
          [[ ${selected[$i]} -eq 0 ]] && all_on=0
        done
        local new_val=1
        [[ $all_on -eq 1 ]] && new_val=0
        for i in $(seq 0 $((total - 1))); do
          selected[$i]=$new_val
        done
        ;;
      '') # Enter - confirm
        break
        ;;
    esac

    draw_menu
  done

  # Restore cursor
  tput cnorm 2>/dev/null || true

  # Write selected keys to result file
  : > "$result_file"
  for i in $(seq 0 $((total - 1))); do
    if [[ ${selected[$i]} -eq 1 ]]; then
      echo "${keys[$i]}" >> "$result_file"
    fi
  done
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_git_root() {
  local dir="${1:-$(pwd)}"
  git -C "$dir" rev-parse --show-toplevel 2>/dev/null || echo "$dir"
}

get_project_id() {
  local dir
  dir=$(get_git_root "${1:-$(pwd)}")
  echo "$dir" | sed 's|/|-|g'
}

get_project_memory_dir() {
  local project_id
  project_id=$(get_project_id "$(get_git_root "${1:-$(pwd)}")")
  echo "$PROJECTS_DIR/$project_id/memory"
}

ensure_memory_index() {
  local mem_dir="$1"
  local index="$mem_dir/MEMORY.md"
  if [[ ! -f "$index" ]]; then
    echo "# Memory Index" > "$index"
    echo "" >> "$index"
  fi
}

get_memory_description() {
  local file="$1"
  grep -m1 '^description:' "$file" 2>/dev/null | sed 's/^description: *//' || echo "(no description)"
}

get_memory_type() {
  local file="$1"
  grep -m1 '^type:' "$file" 2>/dev/null | sed 's/^type: *//' || echo "unknown"
}

is_in_index() {
  local index="$1"
  local filename="$2"
  grep -q "\[$filename\]" "$index" 2>/dev/null
}

add_to_index() {
  local index="$1"
  local filename="$2"
  local description="$3"
  if ! is_in_index "$index" "$filename"; then
    echo "- [$filename]($filename) - $description" >> "$index"
  fi
}

remove_from_index() {
  local index="$1"
  local filename="$2"
  if [[ -f "$index" ]]; then
    local tmp
    tmp=$(mktemp)
    grep -v "\[$filename\]" "$index" > "$tmp" || true
    mv "$tmp" "$index"
  fi
}

# Check for -y/--yes flag in remaining args
has_yes_flag() {
  for arg in "$@"; do
    [[ "$arg" == "-y" || "$arg" == "--yes" ]] && return 0
  done
  return 1
}

# ---------------------------------------------------------------------------
# Memory commands
# ---------------------------------------------------------------------------

cmd_init() {
  local target_dir
  target_dir=$(get_project_memory_dir "${1:-$(pwd)}")
  local project_id
  project_id=$(get_project_id "${1:-$(pwd)}")

  local project_name
  project_name=$(basename "$(get_git_root "${1:-$(pwd)}")")
  echo -e "${CYAN}Initializing project:${NC} $project_name"

  mkdir -p "$target_dir"
  ensure_memory_index "$target_dir"

  # Collect available memories
  local -a mem_labels=()
  local -a mem_keys=()

  for file in "$GLOBAL_DIR"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")
    [[ "$filename" == "MEMORY.md" ]] && continue

    local type
    type=$(get_memory_type "$file")
    local description
    description=$(get_memory_description "$file")

    mem_labels+=("$(printf '%-12s %s' "[$type]" "$description")")
    mem_keys+=("$filename")
  done

  if [[ ${#mem_keys[@]} -eq 0 ]]; then
    echo -e "${DIM}No global memories to sync${NC}"
    return
  fi

  # Interactive selection, auto with -y, or fallback for non-TTY
  local -a chosen_files=()
  local tmp_result
  tmp_result=$(mktemp)

  if has_yes_flag "$@"; then
    chosen_files=("${mem_keys[@]}")
  elif [[ -t 0 ]]; then
    echo ""
    local picker_args=()
    for i in $(seq 0 $((${#mem_keys[@]} - 1))); do
      picker_args+=("${mem_labels[$i]}" "${mem_keys[$i]}")
    done

    multi_select "$tmp_result" "Select memories to install:" "${picker_args[@]}"
    while IFS= read -r line; do
      [[ -n "$line" ]] && chosen_files+=("$line")
    done < "$tmp_result"
    rm -f "$tmp_result"
    echo ""
  else
    # Non-interactive (piped, CI, or agent context) — select all
    chosen_files=("${mem_keys[@]}")
  fi

  # Spinner while syncing
  local spin_chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local spin_i=0
  local count=0

  for filename in "${chosen_files[@]}"; do
    local file="$GLOBAL_DIR/$filename"
    local description
    description=$(get_memory_description "$file")

    printf "\r  ${CYAN}%s${NC} Syncing memories... (%d/%d)" "${spin_chars:spin_i:1}" "$((count + 1))" "${#chosen_files[@]}"
    spin_i=$(( (spin_i + 1) % ${#spin_chars} ))

    cp "$file" "$target_dir/$filename"
    add_to_index "$target_dir/MEMORY.md" "$filename" "$description"
    count=$((count + 1))
  done
  printf "\r\033[2K"

  for filename in "${chosen_files[@]}"; do
    echo -e "  ${GREEN}+${NC} $filename"
  done

  echo ""
  echo -e "${GREEN}Synced $count memories to project${NC}"
  echo -e "${DIM}$target_dir${NC}"

  # Install skills to local project
  local skill_count
  skill_count=$(python3 -c "import json; print(len(json.load(open('$SKILLS_FILE'))))" 2>/dev/null || echo "0")
  local git_root
  git_root=$(get_git_root "${1:-$(pwd)}")
  if [[ "$skill_count" != "0" ]]; then
    echo ""
    skills_add --project-dir "$git_root" "$@"
  fi
}

cmd_sync() {
  local mode="${1:-all}"

  case "$mode" in
    all)
      echo -e "${CYAN}Syncing global memories to all projects...${NC}"
      echo ""
      for project_dir in "$PROJECTS_DIR"/*/; do
        [[ ! -d "$project_dir" ]] && continue
        local project_id
        project_id=$(basename "$project_dir")
        local mem_dir="$project_dir/memory"

        if [[ ! -d "$mem_dir" ]]; then
          echo -e "  ${DIM}$project_id - no memory dir, skipping${NC}"
          continue
        fi

        local count=0
        for file in "$GLOBAL_DIR"/*.md; do
          [[ ! -f "$file" ]] && continue
          local filename
          filename=$(basename "$file")
          [[ "$filename" == "MEMORY.md" ]] && continue

          local description
          description=$(get_memory_description "$file")

          if [[ -f "$mem_dir/$filename" ]] && diff -q "$file" "$mem_dir/$filename" > /dev/null 2>&1; then
            continue
          fi

          cp "$file" "$mem_dir/$filename"
          add_to_index "$mem_dir/MEMORY.md" "$filename" "$description"
          count=$((count + 1))
        done

        if [[ $count -gt 0 ]]; then
          echo -e "  ${GREEN}$project_id - updated $count memories${NC}"
        else
          echo -e "  ${DIM}$project_id - up to date${NC}"
        fi
      done
      ;;
    here)
      cmd_init "$(pwd)"
      ;;
    *)
      echo -e "${RED}Unknown sync mode: $mode${NC}"
      echo "Usage: claude-prefs sync [all|here]"
      exit 1
      ;;
  esac
}

cmd_add() {
  local source="${1:-}"

  if [[ -z "$source" || ! -f "$source" ]]; then
    local project_mem
    project_mem=$(get_project_memory_dir)
    if [[ -f "$project_mem/$source" ]]; then
      source="$project_mem/$source"
    else
      echo -e "${RED}File not found: $source${NC}"
      exit 1
    fi
  fi

  local filename
  filename=$(basename "$source")
  local description
  description=$(get_memory_description "$source")

  cp "$source" "$GLOBAL_DIR/$filename"
  echo -e "${GREEN}Added to global:${NC} $filename"
  echo -e "${DIM}$description${NC}"
}

cmd_remove() {
  local pattern="${1:-}"

  # Handle "remove here" - remove from current project
  if [[ "$pattern" == "here" ]]; then
    cmd_remove_here "${2:-}"
    return
  fi

  if [[ -z "$pattern" ]]; then
    echo -e "${RED}Usage: claude-prefs remove <name or pattern>${NC}"
    echo "  claude-prefs remove here          # remove from current project (picker)"
    echo "  claude-prefs remove here <name>   # remove specific memory from project"
    exit 1
  fi

  # Exact match first
  if [[ -f "$GLOBAL_DIR/$pattern" ]]; then
    rm "$GLOBAL_DIR/$pattern"
    echo -e "${GREEN}Removed from global:${NC} $pattern"
    return
  fi

  # Fuzzy match - find files containing the pattern
  local matches=()
  while IFS= read -r file; do
    matches+=("$file")
  done < <(find "$GLOBAL_DIR" -maxdepth 1 -type f -name "*${pattern}*" 2>/dev/null | sort)

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo -e "${RED}No memories matching: $pattern${NC}"
    exit 1
  fi

  echo -e "${BOLD}Memories matching '${pattern}':${NC}"
  echo ""
  for i in "${!matches[@]}"; do
    local name
    name=$(basename "${matches[$i]}")
    local desc
    desc=$(get_memory_description "${matches[$i]}")
    echo -e "  $((i + 1)). ${CYAN}$name${NC}  ${DIM}$desc${NC}"
  done
  echo ""

  if [[ ${#matches[@]} -eq 1 ]]; then
    read -rp "Remove this memory? [Y/n] " answer
    answer="${answer:-y}"
    if [[ "$answer" =~ ^[Yy] ]]; then
      rm "${matches[0]}"
      echo -e "${GREEN}Removed:${NC} $(basename "${matches[0]}")"
    fi
  else
    read -rp "Enter number to remove (or 'a' for all, empty to cancel): " choice
    if [[ "$choice" == "a" || "$choice" == "A" ]]; then
      for file in "${matches[@]}"; do
        rm "$file"
        echo -e "${GREEN}Removed:${NC} $(basename "$file")"
      done
    elif [[ "$choice" =~ ^[0-9]+$ && "$choice" -ge 1 && "$choice" -le ${#matches[@]} ]]; then
      local idx=$((choice - 1))
      rm "${matches[$idx]}"
      echo -e "${GREEN}Removed:${NC} $(basename "${matches[$idx]}")"
    else
      echo -e "${DIM}Cancelled${NC}"
    fi
  fi
}

cmd_remove_here() {
  local pattern="${1:-}"
  local mem_dir
  mem_dir=$(get_project_memory_dir)

  if [[ ! -d "$mem_dir" ]]; then
    echo -e "${RED}No memory directory for this project${NC}"
    exit 1
  fi

  # Collect project memories
  local -a mem_labels=()
  local -a mem_keys=()

  for file in "$mem_dir"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")
    [[ "$filename" == "MEMORY.md" ]] && continue

    # If pattern given, filter by fuzzy match
    if [[ -n "$pattern" ]] && [[ "$filename" != *"$pattern"* ]]; then
      continue
    fi

    local type
    type=$(get_memory_type "$file")
    local description
    description=$(get_memory_description "$file")

    mem_labels+=("$(printf '%-12s %s' "[$type]" "$description")")
    mem_keys+=("$filename")
  done

  if [[ ${#mem_keys[@]} -eq 0 ]]; then
    if [[ -n "$pattern" ]]; then
      echo -e "${RED}No memories matching '$pattern' in this project${NC}"
    else
      echo -e "${DIM}No memories in this project${NC}"
    fi
    return
  fi

  # If pattern matched exactly one, confirm and remove
  if [[ -n "$pattern" && ${#mem_keys[@]} -eq 1 ]]; then
    echo -e "  ${CYAN}${mem_keys[0]}${NC}  ${DIM}$(get_memory_description "$mem_dir/${mem_keys[0]}")${NC}"
    read -rp "Remove from project? [Y/n] " answer
    answer="${answer:-y}"
    if [[ "$answer" =~ ^[Yy] ]]; then
      rm "$mem_dir/${mem_keys[0]}"
      remove_from_index "$mem_dir/MEMORY.md" "${mem_keys[0]}"
      echo -e "${GREEN}Removed:${NC} ${mem_keys[0]}"
    fi
    return
  fi

  # Multi-select picker
  local tmp_result
  tmp_result=$(mktemp)

  local picker_args=()
  for i in $(seq 0 $((${#mem_keys[@]} - 1))); do
    picker_args+=("${mem_labels[$i]}" "${mem_keys[$i]}")
  done

  # All deselected by default for removal
  local -a defaults=()
  for i in $(seq 0 $((${#mem_keys[@]} - 1))); do
    defaults+=(0)
  done

  multi_select "$tmp_result" "Select memories to remove from project:" --default-off "${picker_args[@]}"

  local -a chosen=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && chosen+=("$line")
  done < "$tmp_result"
  rm -f "$tmp_result"

  if [[ ${#chosen[@]} -eq 0 ]]; then
    echo -e "${DIM}No memories selected${NC}"
    return
  fi

  echo ""
  for filename in "${chosen[@]}"; do
    rm "$mem_dir/$filename"
    remove_from_index "$mem_dir/MEMORY.md" "$filename"
    echo -e "  ${GREEN}-${NC} $filename"
  done

  echo ""
  echo -e "${GREEN}Removed ${#chosen[@]} memories from project${NC}"
}

cmd_list() {
  local scope="${1:-global}"

  if [[ "$scope" == "here" ]]; then
    cmd_list_project
    return
  fi

  echo -e "${BOLD}Global Memories${NC}"
  echo ""

  local count=0
  for file in "$GLOBAL_DIR"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")

    local type
    type=$(get_memory_type "$file")
    local description
    description=$(get_memory_description "$file")

    local type_color="$DIM"
    case "$type" in
      feedback)  type_color="$YELLOW" ;;
      user)      type_color="$CYAN" ;;
      project)   type_color="$GREEN" ;;
      reference) type_color="$RED" ;;
    esac

    echo -e "  ${type_color}[$type]${NC} $filename"
    echo -e "    ${DIM}$description${NC}"
    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    echo -e "  ${DIM}(empty - use 'claude-prefs add <file>' to add memories)${NC}"
  else
    echo ""
    echo -e "${DIM}$count global memories${NC}"
  fi
}

cmd_list_project() {
  local mem_dir
  mem_dir=$(get_project_memory_dir)
  local project_id
  project_id=$(get_project_id)

  echo -e "${BOLD}Project Memories${NC} ${DIM}($project_id)${NC}"
  echo ""

  if [[ ! -d "$mem_dir" ]]; then
    echo -e "  ${DIM}No memory directory for this project${NC}"
    echo -e "  ${DIM}Run 'claude-prefs init' or 'claude-prefs setup' to create one${NC}"
    return
  fi

  local count=0
  for file in "$mem_dir"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")
    [[ "$filename" == "MEMORY.md" ]] && continue

    local type
    type=$(get_memory_type "$file")
    local description
    description=$(get_memory_description "$file")

    local type_color="$DIM"
    case "$type" in
      feedback)  type_color="$YELLOW" ;;
      user)      type_color="$CYAN" ;;
      project)   type_color="$GREEN" ;;
      reference) type_color="$RED" ;;
    esac

    # Check if it matches global version
    local sync_status=""
    if [[ -f "$GLOBAL_DIR/$filename" ]]; then
      if diff -q "$file" "$GLOBAL_DIR/$filename" > /dev/null 2>&1; then
        sync_status=" ${DIM}(synced)${NC}"
      else
        sync_status=" ${YELLOW}(modified locally)${NC}"
      fi
    else
      sync_status=" ${DIM}(local only)${NC}"
    fi

    echo -e "  ${type_color}[$type]${NC} $filename$sync_status"
    echo -e "    ${DIM}$description${NC}"
    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    echo -e "  ${DIM}(empty)${NC}"
  else
    echo ""
    echo -e "${DIM}$count memories${NC}"
  fi
}

cmd_status() {
  echo -e "${BOLD}Project Sync Status${NC}"
  echo ""

  local global_count=0
  for f in "$GLOBAL_DIR"/*.md; do
    [[ -f "$f" ]] && global_count=$((global_count + 1))
  done
  echo -e "  Global memories: ${CYAN}$global_count${NC}"
  echo ""

  for project_dir in "$PROJECTS_DIR"/*/; do
    [[ ! -d "$project_dir" ]] && continue
    local project_id
    project_id=$(basename "$project_dir")
    local mem_dir="$project_dir/memory"

    if [[ ! -d "$mem_dir" ]]; then
      echo -e "  ${DIM}$project_id - no memory${NC}"
      continue
    fi

    local synced=0
    local outdated=0
    local missing=0

    for file in "$GLOBAL_DIR"/*.md; do
      [[ ! -f "$file" ]] && continue
      local filename
      filename=$(basename "$file")

      if [[ ! -f "$mem_dir/$filename" ]]; then
        missing=$((missing + 1))
      elif diff -q "$file" "$mem_dir/$filename" > /dev/null 2>&1; then
        synced=$((synced + 1))
      else
        outdated=$((outdated + 1))
      fi
    done

    local status_parts=()
    [[ $synced -gt 0 ]] && status_parts+=("${GREEN}${synced} synced${NC}")
    [[ $outdated -gt 0 ]] && status_parts+=("${YELLOW}${outdated} outdated${NC}")
    [[ $missing -gt 0 ]] && status_parts+=("${RED}${missing} missing${NC}")

    local status_str
    status_str=$(IFS=', '; echo "${status_parts[*]}")
    echo -e "  $project_id - $status_str"
  done
}

cmd_import() {
  local scope="${1:-here}"
  shift || true

  case "$scope" in
    here)
      import_from_project "$(pwd)"
      ;;
    all)
      echo -e "${CYAN}Importing memories from all projects...${NC}"
      echo ""
      for project_dir in "$PROJECTS_DIR"/*/; do
        [[ ! -d "$project_dir" ]] && continue
        local project_id
        project_id=$(basename "$project_dir")
        local mem_dir="$project_dir/memory"

        if [[ ! -d "$mem_dir" ]]; then
          continue
        fi

        local has_memories=false
        for f in "$mem_dir"/*.md; do
          [[ ! -f "$f" ]] && continue
          local fname
          fname=$(basename "$f")
          [[ "$fname" == "MEMORY.md" ]] && continue
          has_memories=true
          break
        done

        if ! $has_memories; then
          continue
        fi

        echo -e "  ${CYAN}$project_id${NC}"
        import_from_project_dir "$mem_dir" "    "
      done
      ;;
    *)
      echo -e "${RED}Unknown import scope: $scope${NC}"
      echo "Usage: claude-prefs import [here|all]"
      exit 1
      ;;
  esac
}

import_from_project() {
  local project_dir="$1"
  local mem_dir
  mem_dir=$(get_project_memory_dir "$project_dir")

  if [[ ! -d "$mem_dir" ]]; then
    echo -e "${RED}No memory directory found for this project${NC}"
    exit 1
  fi

  echo -e "${CYAN}Importing memories from project...${NC}"
  import_from_project_dir "$mem_dir" "  "
}

import_from_project_dir() {
  local mem_dir="$1"
  local indent="${2:-  }"

  local count=0
  for file in "$mem_dir"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")
    [[ "$filename" == "MEMORY.md" ]] && continue

    local type
    type=$(get_memory_type "$file")
    if [[ "$type" == "project" ]]; then
      echo -e "${indent}${DIM}$filename - project-specific, skipping${NC}"
      continue
    fi

    if [[ -f "$GLOBAL_DIR/$filename" ]]; then
      echo -e "${indent}${DIM}$filename - already exists, skipping${NC}"
      continue
    fi

    cp "$file" "$GLOBAL_DIR/$filename"
    echo -e "${indent}${GREEN}$filename${NC}"
    count=$((count + 1))
  done

  echo -e "${indent}${GREEN}Imported $count memories${NC}"
}

# ---------------------------------------------------------------------------
# Skills commands (skills.sh integration)
# ---------------------------------------------------------------------------

cmd_skills() {
  local subcmd="${1:-list}"
  shift || true

  case "$subcmd" in
    list)    skills_list "$@" ;;
    add)     skills_add "$@" ;;
    remove)  skills_remove "$@" ;;
    install) skills_install "$@" ;;
    *)
      echo -e "${RED}Unknown skills command: $subcmd${NC}"
      echo "Usage: claude-prefs skills [list|add|remove|install]"
      exit 1
      ;;
  esac
}

skills_list() {
  local scope="${1:-global}"

  if [[ "$scope" == "here" ]]; then
    skills_list_here
    return
  fi

  echo -e "${BOLD}Global Skills List${NC}"
  echo ""

  local count
  count=$(python3 -c "import json; print(len(json.load(open('$SKILLS_FILE'))))" 2>/dev/null || echo "0")

  if [[ "$count" == "0" ]]; then
    echo -e "  ${DIM}(empty - use 'claude-prefs skills install <name>' to add skills)${NC}"
    return
  fi

  python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
for s in skills:
    skill = s.get('skill', '')
    desc = s.get('description', '')
    label = f'{s[\"repo\"]}' + (f' / {skill}' if skill else '')
    desc_str = f'  \033[0;90m{desc}\033[0m' if desc else ''
    print(f'  \033[0;36m{label}\033[0m{desc_str}')
"

  echo ""
  echo -e "${DIM}$count skills saved${NC}"
}

skills_list_here() {
  local git_root
  git_root=$(get_git_root "$(pwd)")
  local project_skills_dir="$git_root/.claude/skills"
  local project_name
  project_name=$(basename "$git_root")

  echo -e "${BOLD}Project Skills${NC} ${DIM}($project_name)${NC}"
  echo ""

  if [[ ! -d "$project_skills_dir" ]]; then
    echo -e "  ${DIM}(none - use 'claude-prefs skills add' to add skills to this project)${NC}"
    return
  fi

  local count=0
  for entry in "$project_skills_dir"/*/; do
    [[ ! -d "$entry" ]] && continue
    local name
    name=$(basename "$entry")

    if [[ -L "${entry%/}" || -L "$project_skills_dir/$name" ]]; then
      local target
      target=$(readlink "$project_skills_dir/$name" 2>/dev/null || echo "")
      echo -e "  ${CYAN}$name${NC} ${DIM}-> $target${NC}"
    else
      echo -e "  ${CYAN}$name${NC}"
    fi
    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    echo -e "  ${DIM}(none - use 'claude-prefs skills add' to add skills to this project)${NC}"
    return
  fi

  echo ""
  echo -e "${DIM}$count skills linked${NC}"
}

skills_install() {
  local input="${1:-}"
  shift 2>/dev/null || true
  local flags="$*"

  if [[ -z "$input" ]]; then
    echo -e "${RED}Usage: claude-prefs skills install <name or owner/repo> [--skill name]${NC}"
    exit 1
  fi

  local repo=""
  local skill=""

  local agents_dir="$HOME/.agents/skills"

  if [[ "$input" == *"/"* ]]; then
    # owner/repo format - parse --skill from flags
    repo="$input"
    if [[ "$flags" == *"--skill "* ]]; then
      skill=$(echo "$flags" | sed 's/.*--skill //' | awk '{print $1}')
    fi
  elif [[ -d "$agents_dir/$input" ]]; then
    # Already downloaded locally - resolve repo/skill from global list or just use as-is
    skill="$input"
    local found_repo
    found_repo=$(python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
for s in skills:
    if s.get('skill', '') == '$input':
        print(s['repo'])
        break
" 2>/dev/null)
    if [[ -n "$found_repo" ]]; then
      repo="$found_repo"
    else
      # Exists locally but not in global list - just symlink, skip global add
      repo=""
    fi
    echo -e "${GREEN}Found locally:${NC} $skill"
  else
    # Skill name - check global list first, then search skills.sh
    local found_entry
    found_entry=$(python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
for s in skills:
    if '$input' in s.get('skill', '') or '$input' in s['repo']:
        print(s['repo'] + '|' + s.get('skill', ''))
        break
" 2>/dev/null)

    if [[ -n "$found_entry" ]]; then
      repo="${found_entry%|*}"
      skill="${found_entry#*|}"
      echo -e "${GREEN}Found in global list:${NC} $repo / $skill"
    else
      # Search skills.sh
      echo -e "${DIM}Searching skills.sh for '$input'...${NC}"
      local find_result
      find_result=$(npx --yes skills find "$input" 2>/dev/null | head -20)

      local top_match
      top_match=$(echo "$find_result" | sed 's/\x1b\[[0-9;]*m//g' | grep -m1 '@' | awk '{print $1}')

      if [[ -z "$top_match" ]]; then
        echo -e "${RED}No skills found matching '$input'${NC}"
        return 1
      fi

      repo="${top_match%@*}"
      skill="${top_match#*@}"
      echo -e "${GREEN}Found:${NC} $repo --skill $skill"
    fi
  fi

  # Add to global list if not already there (skip if repo is empty - local only)
  if [[ -n "$repo" ]]; then
    local exists
    exists=$(python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
print('yes' if any(s['repo'] == '$repo' and s.get('skill', '') == '$skill' for s in skills) else 'no')
" 2>/dev/null || echo "no")

    if [[ "$exists" != "yes" ]]; then
      python3 -c "
import json
entry = {'repo': '$repo'}
if '$skill': entry['skill'] = '$skill'
if '$flags' and '--skill' not in '$flags': entry['flags'] = '$flags'
skills = json.load(open('$SKILLS_FILE'))
skills.append(entry)
json.dump(skills, open('$SKILLS_FILE', 'w'), indent=2)
"
      local display="$repo"
      [[ -n "$skill" ]] && display="$display / $skill"
      echo -e "${GREEN}Added to skills list:${NC} $display"
    fi
  fi

  # Install and symlink to current project
  local skill_name="${skill:-$(basename "$repo")}"
  local git_root
  git_root=$(get_git_root "$(pwd)")
  local project_skills_dir="$git_root/.claude/skills"

  # Fetch if not already downloaded
  if [[ ! -d "$agents_dir/$skill_name" ]]; then
    echo ""
    echo -e "${CYAN}↓${NC} Fetching $skill_name..."
    local install_flags="-y -g"
    [[ -n "$skill" ]] && install_flags="$install_flags --skill $skill"
    [[ -n "$flags" && "$flags" != *"--skill"* ]] && install_flags="$install_flags $flags"
    npx skills add "$repo" $install_flags 2>&1 | sed 's/^/  /'
  fi

  # Symlink to current project
  if [[ -d "$agents_dir/$skill_name" ]]; then
    mkdir -p "$project_skills_dir"
    if [[ ! -e "$project_skills_dir/$skill_name" ]]; then
      ln -sf "$agents_dir/$skill_name" "$project_skills_dir/$skill_name"
      echo -e "${GREEN}+${NC} Symlinked to ${DIM}$project_skills_dir/$skill_name${NC}"
    else
      echo -e "${DIM}-${NC} Already in project ${DIM}($project_skills_dir/$skill_name)${NC}"
    fi
  fi
}

skills_remove() {
  local input="${1:-}"

  if [[ "$input" == "here" ]]; then
    skills_remove_here "${2:-}"
    return
  fi

  # Build list of all skills (or filter by input)
  local -a skill_labels=()
  local -a skill_keys=()

  local idx=0
  while IFS='|' read -r repo skill desc; do
    local label="$repo"
    [[ -n "$skill" ]] && label="$label / $skill"
    [[ -n "$desc" ]] && label="$label  ($desc)"

    # If input given, filter by fuzzy match
    if [[ -n "$input" ]]; then
      if [[ "$skill" != *"$input"* && "$repo" != *"$input"* ]]; then
        idx=$((idx + 1))
        continue
      fi
    fi

    skill_labels+=("$label")
    skill_keys+=("$idx")
    idx=$((idx + 1))
  done < <(python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
for s in skills:
    print(s['repo'] + '|' + s.get('skill', '') + '|' + s.get('description', ''))
")

  if [[ ${#skill_keys[@]} -eq 0 ]]; then
    if [[ -n "$input" ]]; then
      echo -e "${RED}No skills matching: $input${NC}"
    else
      echo -e "${DIM}No skills saved${NC}"
    fi
    return
  fi

  # Use multi-select picker (default off)
  local tmp_result
  tmp_result=$(mktemp)

  local picker_args=()
  for i in $(seq 0 $((${#skill_keys[@]} - 1))); do
    picker_args+=("${skill_labels[$i]}" "${skill_keys[$i]}")
  done

  multi_select "$tmp_result" "Select skills to remove:" --default-off "${picker_args[@]}"

  local -a chosen=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && chosen+=("$line")
  done < "$tmp_result"
  rm -f "$tmp_result"

  if [[ ${#chosen[@]} -eq 0 ]]; then
    echo -e "${DIM}No skills selected${NC}"
    return
  fi

  # Remove by indices (reverse order to preserve positions)
  local indices_json
  indices_json=$(printf '%s,' "${chosen[@]}")
  indices_json="[${indices_json%,}]"

  echo ""
  python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
to_remove = sorted($indices_json, reverse=True)
removed = []
for idx in to_remove:
    s = skills.pop(idx)
    skill = s.get('skill', '')
    label = f'{s[\"repo\"]} / {skill}' if skill else s['repo']
    removed.append(label)
json.dump(skills, open('$SKILLS_FILE', 'w'), indent=2)
for label in removed:
    print(label)
" 2>/dev/null | while IFS= read -r label; do
    echo -e "  ${GREEN}-${NC} $label"
  done

  echo ""
  echo -e "${GREEN}Removed ${#chosen[@]} skills${NC}"
}

skills_remove_here() {
  local pattern="${1:-}"
  local git_root
  git_root=$(get_git_root "$(pwd)")
  local project_skills_dir="$git_root/.claude/skills"
  local project_name
  project_name=$(basename "$git_root")

  if [[ ! -d "$project_skills_dir" ]]; then
    echo -e "${DIM}No skills linked in this project${NC}"
    return
  fi

  # Collect linked skills
  local -a skill_labels=()
  local -a skill_keys=()

  for entry in "$project_skills_dir"/*/; do
    [[ ! -d "$entry" ]] && continue
    local name
    name=$(basename "$entry")

    # Filter by pattern if given
    if [[ -n "$pattern" ]] && [[ "$name" != *"$pattern"* ]]; then
      continue
    fi

    skill_labels+=("$name")
    skill_keys+=("$name")
  done

  if [[ ${#skill_keys[@]} -eq 0 ]]; then
    if [[ -n "$pattern" ]]; then
      echo -e "${RED}No skills matching '$pattern' in this project${NC}"
    else
      echo -e "${DIM}No skills linked in this project${NC}"
    fi
    return
  fi

  # Multi-select picker (default off)
  local tmp_result
  tmp_result=$(mktemp)

  local picker_args=()
  for i in $(seq 0 $((${#skill_keys[@]} - 1))); do
    picker_args+=("${skill_labels[$i]}" "${skill_keys[$i]}")
  done

  multi_select "$tmp_result" "Select skills to unlink from $project_name:" --default-off "${picker_args[@]}"

  local -a chosen=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && chosen+=("$line")
  done < "$tmp_result"
  rm -f "$tmp_result"

  if [[ ${#chosen[@]} -eq 0 ]]; then
    echo -e "${DIM}No skills selected${NC}"
    return
  fi

  echo ""
  for name in "${chosen[@]}"; do
    rm -rf "$project_skills_dir/$name"
    echo -e "  ${GREEN}-${NC} $name"
  done

  echo ""
  echo -e "${GREEN}Unlinked ${#chosen[@]} skills from project${NC}"
}

skills_add() {
  # Optional: pass --project-dir <dir> to install into project's .claude/skills/
  local project_dir=""
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-dir)
        project_dir="$2"
        shift 2
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done
  set -- "${args[@]+"${args[@]}"}"

  local count
  count=$(python3 -c "import json; print(len(json.load(open('$SKILLS_FILE'))))" 2>/dev/null || echo "0")

  if [[ "$count" == "0" ]]; then
    echo -e "  ${DIM}No skills saved. Use 'claude-prefs skills install <name>' first.${NC}"
    return
  fi

  # Build picker data from skills list
  # Each entry has: label, key (index), repo, skill, flags
  local -a skill_labels=()
  local -a skill_keys=()
  local -a skill_repos=()
  local -a skill_skills=()
  local -a skill_flags_arr=()

  local idx=0
  while IFS='|' read -r repo skill flags desc; do
    local label="$repo"
    [[ -n "$skill" ]] && label="$label --skill $skill"
    [[ -n "$desc" ]] && label="$label  ${DIM}($desc)${NC}"
    skill_labels+=("$label")
    skill_keys+=("$idx")
    skill_repos+=("$repo")
    skill_skills+=("$skill")
    skill_flags_arr+=("$flags")
    idx=$((idx + 1))
  done < <(python3 -c "
import json
skills = json.load(open('$SKILLS_FILE'))
for s in skills:
    print(s['repo'] + '|' + s.get('skill', '') + '|' + s.get('flags', '') + '|' + s.get('description', ''))
")

  # Interactive selection, auto with -y, or fallback for non-TTY
  local -a chosen_indices=()
  local tmp_result
  tmp_result=$(mktemp)

  if has_yes_flag "$@"; then
    chosen_indices=("${skill_keys[@]}")
  elif [[ -t 0 ]]; then
    echo ""
    local picker_args=()
    for i in $(seq 0 $((${#skill_keys[@]} - 1))); do
      picker_args+=("${skill_labels[$i]}" "${skill_keys[$i]}")
    done

    multi_select "$tmp_result" "Select skills to install:" "${picker_args[@]}"
    while IFS= read -r line; do
      [[ -n "$line" ]] && chosen_indices+=("$line")
    done < "$tmp_result"
    rm -f "$tmp_result"
    echo ""
  else
    # Non-interactive — select all
    chosen_indices=("${skill_keys[@]}")
  fi

  if [[ ${#chosen_indices[@]} -eq 0 ]]; then
    echo -e "${DIM}No skills selected${NC}"
    return
  fi

  local agents_dir="$HOME/.agents/skills"
  local target_skills_dir
  if [[ -n "$project_dir" ]]; then
    target_skills_dir="$project_dir/.claude/skills"
  else
    target_skills_dir="$CLAUDE_DIR/skills"
  fi
  mkdir -p "$target_skills_dir"

  echo -e "${BOLD}Adding ${#chosen_indices[@]} skills...${NC}"
  echo ""

  local added=0 fetched=0 skipped=0
  for idx in "${chosen_indices[@]}"; do
    local repo="${skill_repos[$idx]}"
    local skill="${skill_skills[$idx]}"
    local flags="${skill_flags_arr[$idx]}"
    local skill_name="${skill:-$(basename "$repo")}"

    if [[ ! -d "$agents_dir/$skill_name" ]]; then
      # Not downloaded yet, fetch it
      echo -e "  ${CYAN}↓${NC} $skill_name ${DIM}(downloading)${NC}"

      local install_flags="-y -g"
      [[ -n "$skill" ]] && install_flags="$install_flags --skill $skill"
      [[ -n "$flags" ]] && install_flags="$install_flags $flags"

      npx skills add "$repo" $install_flags 2>&1 | sed 's/^/    /'
      fetched=$((fetched + 1))
    fi

    # Ensure symlink exists in target
    if [[ -d "$agents_dir/$skill_name" ]]; then
      if [[ ! -e "$target_skills_dir/$skill_name" ]]; then
        ln -sf "$agents_dir/$skill_name" "$target_skills_dir/$skill_name"
      fi
      echo -e "  ${GREEN}+${NC} $skill_name"
      added=$((added + 1))
    fi
  done

  echo ""
  echo -e "${GREEN}Linked $added skills${NC} ${DIM}to $target_skills_dir${NC}"
}

# ---------------------------------------------------------------------------
# Defaults command - load bundled memories and skills
# ---------------------------------------------------------------------------

cmd_defaults() {
  local subcmd="${1:-load}"
  shift || true

  case "$subcmd" in
    load) defaults_load "$@" ;;
    list) defaults_list ;;
    *)
      echo -e "${RED}Unknown defaults command: $subcmd${NC}"
      echo "Usage: claude-prefs defaults [load|list]"
      exit 1
      ;;
  esac
}

defaults_list() {
  if [[ ! -d "$DEFAULTS_DIR" ]]; then
    echo -e "${RED}Defaults directory not found at $DEFAULTS_DIR${NC}"
    echo -e "${DIM}This command requires the full repo clone, not a standalone install.${NC}"
    exit 1
  fi

  echo -e "${BOLD}Bundled Defaults${NC}"

  echo ""
  echo -e "  ${BOLD}Memories:${NC}"
  for file in "$DEFAULTS_DIR/memories"/*.md; do
    [[ ! -f "$file" ]] && continue
    local desc
    desc=$(get_memory_description "$file")
    echo -e "    ${CYAN}$(basename "$file")${NC}"
    echo -e "      ${DIM}$desc${NC}"
  done

  echo ""
  echo -e "  ${BOLD}Skills:${NC}"
  python3 -c "
import json
skills = json.load(open('$DEFAULTS_DIR/skills.json'))
for s in skills:
    desc = s.get('description', '')
    skill = s.get('skill', '')
    repo = s['repo']
    label = f'{repo} --skill {skill}' if skill else repo
    print(f'    \033[0;36m{label}\033[0m')
    if desc:
        print(f'      \033[0;90m{desc}\033[0m')
" 2>/dev/null
}

defaults_load() {
  if [[ ! -d "$DEFAULTS_DIR" ]]; then
    echo -e "${RED}Defaults directory not found at $DEFAULTS_DIR${NC}"
    echo -e "${DIM}This command requires the full repo clone, not a standalone install.${NC}"
    exit 1
  fi

  echo -e "${BOLD}Loading defaults...${NC}"
  echo ""

  # Load default memories
  echo -e "  ${BOLD}Memories:${NC}"
  local mem_count=0
  local mem_skipped=0
  for file in "$DEFAULTS_DIR/memories"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")

    if [[ -f "$GLOBAL_DIR/$filename" ]]; then
      mem_skipped=$((mem_skipped + 1))
      continue
    fi

    cp "$file" "$GLOBAL_DIR/$filename"
    echo -e "    ${GREEN}+ $filename${NC}"
    mem_count=$((mem_count + 1))
  done
  if [[ $mem_count -gt 0 ]]; then
    echo -e "    ${GREEN}Added $mem_count new memories${NC}"
  else
    echo -e "    ${DIM}All $mem_skipped default memories already loaded${NC}"
  fi

  # Load default skills
  echo ""
  echo -e "  ${BOLD}Skills:${NC}"
  local skill_count=0
  python3 -c "
import json

defaults = json.load(open('$DEFAULTS_DIR/skills.json'))
try:
    existing = json.load(open('$SKILLS_FILE'))
except:
    existing = []

# Build set of existing (repo, skill) pairs
existing_set = set()
for s in existing:
    existing_set.add((s['repo'], s.get('skill', '')))

added = 0
skipped = 0
for s in defaults:
    key = (s['repo'], s.get('skill', ''))
    if key not in existing_set:
        existing.append(s)
        existing_set.add(key)
        skill = s.get('skill', '')
        label = f'{s[\"repo\"]} / {skill}' if skill else s['repo']
        print(f'    \033[0;32m+ {label}\033[0m')
        added += 1
    else:
        skipped += 1

json.dump(existing, open('$SKILLS_FILE', 'w'), indent=2)
if added > 0:
    print(f'    \033[0;32mAdded {added} new skills\033[0m')
else:
    print(f'    \033[0;90mAll {skipped} default skills already loaded\033[0m')
" 2>/dev/null

  echo ""
  echo -e "${GREEN}Done!${NC} Run ${CYAN}claude-prefs init${NC} to add memories and skills to a project."
}

# Silent version for setup - loads defaults without the "run skills install" message
defaults_load_quiet() {
  if [[ ! -d "$DEFAULTS_DIR" ]]; then
    return
  fi

  local mem_count=0
  for file in "$DEFAULTS_DIR/memories"/*.md; do
    [[ ! -f "$file" ]] && continue
    local filename
    filename=$(basename "$file")
    [[ -f "$GLOBAL_DIR/$filename" ]] && continue
    cp "$file" "$GLOBAL_DIR/$filename"
    echo -e "  ${GREEN}+ $filename${NC}"
    mem_count=$((mem_count + 1))
  done

  python3 -c "
import json
defaults = json.load(open('$DEFAULTS_DIR/skills.json'))
try:
    existing = json.load(open('$SKILLS_FILE'))
except:
    existing = []
existing_set = set((s['repo'], s.get('skill', '')) for s in existing)
added = 0
for s in defaults:
    key = (s['repo'], s.get('skill', ''))
    if key not in existing_set:
        existing.append(s)
        existing_set.add(key)
        added += 1
json.dump(existing, open('$SKILLS_FILE', 'w'), indent=2)
if added > 0:
    print(f'  \033[0;32m+ {added} default skills added to list\033[0m')
else:
    print(f'  \033[0;90mAll defaults already loaded\033[0m')
" 2>/dev/null

  if [[ $mem_count -gt 0 ]]; then
    echo -e "  ${GREEN}+ $mem_count default memories added${NC}"
  else
    echo -e "  ${DIM}All defaults already loaded${NC}"
  fi
}

# ---------------------------------------------------------------------------
# Setup command - full project setup (memories + skills)
# ---------------------------------------------------------------------------

cmd_setup() {
  echo -e "${BOLD}Global Setup${NC}"
  echo ""

  # Load defaults into global store
  if [[ -d "$DEFAULTS_DIR" ]]; then
    defaults_load_quiet
  else
    echo -e "${DIM}No defaults directory found${NC}"
  fi

  echo ""
  echo -e "${GREEN}Global setup complete!${NC}"

  # Ask to init current project
  if [[ -t 0 ]]; then
    echo ""
    read -rp "Initialize current project? [Y/n] " answer
    answer="${answer:-y}"
    if [[ "$answer" =~ ^[Yy] ]]; then
      echo ""
      cmd_init "$@"
    fi
  fi
}

