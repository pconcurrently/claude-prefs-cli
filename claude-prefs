  echo -e "  ${CYAN}skills remove here${NC} [name] Unlink skills from current project (picker)"
  echo ""
  echo -e "${BOLD}DEFAULTS${NC}"
  echo -e "  ${CYAN}defaults load${NC}            Load bundled default memories and skills"
  echo -e "  ${CYAN}defaults list${NC}            Preview bundled defaults"
  echo ""
  echo -e "${BOLD}FLAGS${NC}"
  echo -e "  ${CYAN}-y, --yes${NC}                Skip interactive picker, select all"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

UPDATE_CHECK_FILE="$CLAUDE_DIR/.claude-prefs-last-update-check"

check_for_updates() {
  [[ ! -d "$SCRIPT_DIR/.git" ]] && return

  local update_available_file="$CLAUDE_DIR/.claude-prefs-update-available"

  # Show notification if a background check already found an update
  if [[ -f "$update_available_file" ]]; then
    echo -e "${YELLOW}Update available!${NC} Run ${CYAN}claude-prefs update${NC} to update."
    echo ""
  fi

  # Only fetch once per day
  local now last_check=0
  now=$(date +%s)
  if [[ -f "$UPDATE_CHECK_FILE" ]]; then
    last_check=$(cat "$UPDATE_CHECK_FILE" 2>/dev/null || echo 0)
  fi
  if [[ $((now - last_check)) -lt 86400 ]]; then
    return
  fi
  echo "$now" > "$UPDATE_CHECK_FILE"

  # Fetch in background so the command isn't delayed
  (
    git -C "$SCRIPT_DIR" fetch --quiet 2>/dev/null || exit 0
    local_head=$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null) || exit 0
    remote_head=$(git -C "$SCRIPT_DIR" rev-parse '@{u}' 2>/dev/null) || exit 0
    if [[ "$local_head" != "$remote_head" ]]; then
      touch "$update_available_file"
    else
      rm -f "$update_available_file"
    fi
  ) &
  disown 2>/dev/null
}

cmd_update() {
  if [[ ! -d "$SCRIPT_DIR/.git" ]]; then
    echo -e "${RED}Not installed via git clone. Re-run the install script.${NC}"
    return 1
  fi

  local old_head new_head
  old_head=$(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null)

  echo -ne "  ⠋ Checking for updates..."
  git -C "$SCRIPT_DIR" fetch --quiet 2>/dev/null

  local local_head remote_head
  local_head=$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null)
  remote_head=$(git -C "$SCRIPT_DIR" rev-parse '@{u}' 2>/dev/null)

  if [[ "$local_head" == "$remote_head" ]]; then
    echo -e "\r\033[2K  ${GREEN}✓${NC} Already on latest version ${DIM}($old_head)${NC}"
    return
  fi

  echo -ne "\r\033[2K  ⠹ Pulling latest..."
  git -C "$SCRIPT_DIR" pull --quiet 2>/dev/null
  new_head=$(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null)

  local commit_count
  commit_count=$(git -C "$SCRIPT_DIR" rev-list "$old_head".."$new_head" --count 2>/dev/null || echo "?")

  echo -e "\r\033[2K  ${GREEN}Updated${NC} ${DIM}$old_head${NC} → ${DIM}$new_head${NC} ${DIM}($commit_count new commits)${NC}"

  # Load any new defaults bundled with the update
  defaults_load_quiet

  # Clear update notification and refresh timestamp
  rm -f "$CLAUDE_DIR/.claude-prefs-update-available"
  date +%s > "$UPDATE_CHECK_FILE"
}

command="${1:-help}"
shift || true

# Check for updates on every run (throttled to once/day)
check_for_updates

case "$command" in
  list)    cmd_list "$@" ;;
  status)  cmd_status "$@" ;;
  add)     cmd_add "$@" ;;
  remove)  cmd_remove "$@" ;;
  init)    cmd_init "$@" ;;
  sync)    cmd_sync "$@" ;;
  import)  cmd_import "$@" ;;
  skills)   cmd_skills "$@" ;;
  defaults) cmd_defaults "$@" ;;
  setup)    cmd_setup "$@" ;;
  update)   cmd_update ;;
  help|-h|--help) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $command${NC}"
    cmd_help
    exit 1
    ;;
esac
